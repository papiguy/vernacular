# 30-day dependency cooldown.
#
# Refuses to install any package (direct or transitive) whose newest
# matching release is younger than this many minutes. Mitigates supply-
# chain risks from compromised packages and typosquatting where the
# malicious release is usually caught and yanked within days.
#
# 43200 minutes == 30 days.
#
# Requires pnpm 10 or newer (see packageManager + engines.pnpm in
# package.json).
minimum-release-age=43200

# Pin exact versions, never ranges. `pnpm add` writes the resolved
# version with no `^`/`~` prefix, so a direct dependency never floats to
# a newer release on a later install. Transitive dependencies are pinned
# by the committed pnpm-lock.yaml (CI installs with --frozen-lockfile),
# so the whole tree is reproducible and nothing upgrades automatically.
save-exact=true
save-prefix=

# Cooldown exclusions: see
# docs/knowledge/decisions/ADR-0013-cooldown-exclusions.md.
#
# Three categories of exclusion, each documented in the ADR:
# 1. Rollup per-platform native binaries (coordinated release artifacts
#    from rollup's own CI; no independent maintainer access).
# 2. typescript-eslint monorepo packages (multi-maintainer, formally
#    governed; canary releases otherwise block pnpm resolution).
# 3. Babel infrastructure packages (multi-maintainer monorepo with
#    coordinated releases; helpers are tiny utilities, not standalone
#    code with independent risk).
minimum-release-age-exclude[]=@rollup/rollup-android-arm-eabi
minimum-release-age-exclude[]=@rollup/rollup-android-arm64
minimum-release-age-exclude[]=@rollup/rollup-darwin-arm64
minimum-release-age-exclude[]=@rollup/rollup-darwin-x64
minimum-release-age-exclude[]=@rollup/rollup-freebsd-arm64
minimum-release-age-exclude[]=@rollup/rollup-freebsd-x64
minimum-release-age-exclude[]=@rollup/rollup-linux-arm-gnueabihf
minimum-release-age-exclude[]=@rollup/rollup-linux-arm-musleabihf
minimum-release-age-exclude[]=@rollup/rollup-linux-arm64-gnu
minimum-release-age-exclude[]=@rollup/rollup-linux-arm64-musl
minimum-release-age-exclude[]=@rollup/rollup-linux-loong64-gnu
minimum-release-age-exclude[]=@rollup/rollup-linux-loong64-musl
minimum-release-age-exclude[]=@rollup/rollup-linux-ppc64-gnu
minimum-release-age-exclude[]=@rollup/rollup-linux-ppc64-musl
minimum-release-age-exclude[]=@rollup/rollup-linux-riscv64-gnu
minimum-release-age-exclude[]=@rollup/rollup-linux-riscv64-musl
minimum-release-age-exclude[]=@rollup/rollup-linux-s390x-gnu
minimum-release-age-exclude[]=@rollup/rollup-linux-x64-gnu
minimum-release-age-exclude[]=@rollup/rollup-linux-x64-musl
minimum-release-age-exclude[]=@rollup/rollup-openbsd-x64
minimum-release-age-exclude[]=@rollup/rollup-openharmony-arm64
minimum-release-age-exclude[]=@rollup/rollup-win32-arm64-msvc
minimum-release-age-exclude[]=@rollup/rollup-win32-ia32-msvc
minimum-release-age-exclude[]=@rollup/rollup-win32-x64-gnu
minimum-release-age-exclude[]=@rollup/rollup-win32-x64-msvc

# typescript-eslint monorepo
minimum-release-age-exclude[]=@typescript-eslint/eslint-plugin
minimum-release-age-exclude[]=@typescript-eslint/parser
minimum-release-age-exclude[]=@typescript-eslint/scope-manager
minimum-release-age-exclude[]=@typescript-eslint/type-utils
minimum-release-age-exclude[]=@typescript-eslint/types
minimum-release-age-exclude[]=@typescript-eslint/typescript-estree
minimum-release-age-exclude[]=@typescript-eslint/utils
minimum-release-age-exclude[]=@typescript-eslint/visitor-keys
minimum-release-age-exclude[]=typescript-eslint

# Babel infrastructure (helpers, parser, types)
minimum-release-age-exclude[]=@babel/code-frame
minimum-release-age-exclude[]=@babel/compat-data
minimum-release-age-exclude[]=@babel/core
minimum-release-age-exclude[]=@babel/generator
minimum-release-age-exclude[]=@babel/helper-compilation-targets
minimum-release-age-exclude[]=@babel/helper-environment-visitor
minimum-release-age-exclude[]=@babel/helper-function-name
minimum-release-age-exclude[]=@babel/helper-hoist-variables
minimum-release-age-exclude[]=@babel/helper-module-imports
minimum-release-age-exclude[]=@babel/helper-module-transforms
minimum-release-age-exclude[]=@babel/helper-plugin-utils
minimum-release-age-exclude[]=@babel/helper-simple-access
minimum-release-age-exclude[]=@babel/helper-split-export-declaration
minimum-release-age-exclude[]=@babel/helper-string-parser
minimum-release-age-exclude[]=@babel/helper-validator-identifier
minimum-release-age-exclude[]=@babel/helper-validator-option
minimum-release-age-exclude[]=@babel/helpers
minimum-release-age-exclude[]=@babel/highlight
minimum-release-age-exclude[]=@babel/parser
minimum-release-age-exclude[]=@babel/template
minimum-release-age-exclude[]=@babel/traverse
minimum-release-age-exclude[]=@babel/types
