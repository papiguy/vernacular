{
  "name": "vernacular",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "license": "Apache-2.0",
  "description": "Open-source floor planner for power users, with first-class support for historic and period-vernacular architecture.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "knowledge:index": "node scripts/knowledge-index.mjs",
    "pack:build": "node scripts/pack/vernacular-pack.mjs build",
    "pack:validate": "node scripts/pack/vernacular-pack.mjs validate",
    "rgb:audit": "node scripts/rgb-audit/rgb-audit.mjs",
    "integration:audit": "node scripts/integration-audit/integration-audit.mjs",
    "dup": "jscpd --silent .",
    "storybook": "storybook dev -p 6006 --no-open",
    "build-storybook": "storybook build",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:update-snapshots": "PLAYWRIGHT_VERSION=$(node -e \"console.log(require('@playwright/test/package.json').version)\") && docker run --rm -v \"$(pwd)\":/work -w /work -e HOME=/tmp mcr.microsoft.com/playwright:v${PLAYWRIGHT_VERSION}-noble sh -c 'corepack enable && corepack prepare pnpm@10.33.4 --activate && pnpm install --frozen-lockfile && pnpm build && pnpm exec playwright test --update-snapshots'",
    "lhci": "lhci autorun --config=./lighthouserc.json",
    "lhci:collect": "lhci collect --config=./lighthouserc.json",
    "mutate": "stryker run",
    "mutate:check": "stryker run --dryRun",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.33.0"
  },
  "packageManager": "pnpm@10.33.4",
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml,html,css}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@react-three/fiber": "9.6.1",
    "fflate": "0.8.2",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "three": "0.184.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.11.3",
    "@commitlint/cli": "21.0.1",
    "@commitlint/config-conventional": "21.0.1",
    "@eslint/js": "9.39.4",
    "@lhci/cli": "0.15.1",
    "@playwright/test": "1.60.0",
    "@storybook/react-vite": "10.4.0",
    "@stryker-mutator/core": "8.7.1",
    "@stryker-mutator/typescript-checker": "8.7.1",
    "@stryker-mutator/vitest-runner": "8.7.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "20.19.41",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/three": "0.184.1",
    "@vitejs/plugin-react": "4.7.0",
    "@vitest/coverage-v8": "1.6.1",
    "@webgpu/types": "0.1.70",
    "eslint": "9.39.4",
    "eslint-plugin-boundaries": "6.0.2",
    "eslint-plugin-react-hooks": "5.2.0",
    "eslint-plugin-react-refresh": "0.4.26",
    "eslint-plugin-unused-imports": "4.4.1",
    "globals": "15.15.0",
    "husky": "9.1.7",
    "jscpd": "4.2.3",
    "jsdom": "24.1.3",
    "lint-staged": "17.0.5",
    "prettier": "3.8.3",
    "storybook": "10.4.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.60.1",
    "vite": "5.4.21",
    "vitest": "1.6.1"
  },
  "pnpm": {
    "overrides": {
      "rollup": "4.60.4",
      "esbuild": "0.25.0",
      "uuid": "11.1.1"
    }
  }
}
